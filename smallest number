import java.util.Scanner;
public static void main(String args[]){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int large=sc.nextInt();
    for(int i=0;i<n;i++){
        int num=sc.nextInt();
        if(large>num){
            large=num;
            System.out.println(num);
        }
    }
}
